# History cleanup utilities.
# Sourced by .bash_aliases. Requires zsh or bash; hist-clean requires fzf.

# hd [N] — delete the last N commands from history (default 1).
# Also removes the hd invocation itself.
hd() {
  local n=${1:-1}

  # Save current session history to HISTFILE.
  fc -W

  local histfile="${HISTFILE:-$HOME/.history}"
  if [[ ! -f "$histfile" ]]; then
    echo "hd: HISTFILE not found: $histfile" >&2
    return 1
  fi

  # +1 to also remove the hd call itself.
  local total=$((n + 1))

  if [[ -n "$ZSH_VERSION" ]]; then
    # Extended history format: ": epoch:elapsed;command"
    # Multi-line commands have continuation lines without the ": " prefix.
    # Count entries (lines starting with ": ") from the bottom.
    local entries_found=0
    local lines_to_remove=0
    local -a removed_cmds=()
    while IFS= read -r line; do
      lines_to_remove=$((lines_to_remove + 1))
      if [[ "$line" == ": "* ]]; then
        entries_found=$((entries_found + 1))
        # Skip the hd call itself (last entry), collect the rest.
        if [[ $entries_found -gt 1 ]]; then
          local cmd="${line#: [0-9]##:[0-9]##;}"
          removed_cmds+=("$cmd")
        fi
        [[ $entries_found -ge $total ]] && break
      fi
    done < <(tail -r "$histfile" 2>/dev/null || tac "$histfile")

    if [[ $entries_found -eq 0 ]]; then
      echo "hd: history is empty" >&2
      return 1
    fi

    # Remove the last lines_to_remove lines.
    local total_lines
    total_lines=$(wc -l < "$histfile")
    local keep=$((total_lines - lines_to_remove))
    [[ $keep -lt 0 ]] && keep=0
    head -n "$keep" "$histfile" > "${histfile}.tmp" && mv "${histfile}.tmp" "$histfile"
  else
    # Bash: one command per line.
    local -a removed_cmds=()
    local total_lines
    total_lines=$(wc -l < "$histfile")
    # Collect the commands being removed (skip last line which is the hd call).
    local start=$((total_lines - total + 1))
    [[ $start -lt 1 ]] && start=1
    local end=$((total_lines - 1))
    local i=0
    while IFS= read -r line; do
      i=$((i + 1))
      [[ $i -ge $start && $i -le $end ]] && removed_cmds+=("$line")
    done < "$histfile"

    local keep=$((total_lines - total))
    [[ $keep -lt 0 ]] && keep=0
    head -n "$keep" "$histfile" > "${histfile}.tmp" && mv "${histfile}.tmp" "$histfile"
  fi

  # Reload history from the updated file.
  fc -R
  echo "Removed $n $(if [[ $n -eq 1 ]]; then echo entry; else echo entries; fi) from history:"
  for cmd in "${removed_cmds[@]}"; do
    echo "  $cmd"
  done
}

# hist-clean — interactively select and remove commands from history via fzf.
hist-clean() {
  if ! command -v fzf >/dev/null 2>&1; then
    echo "hist-clean: fzf is required but not found" >&2
    return 1
  fi

  # Save current session history to HISTFILE.
  fc -W

  local histfile="${HISTFILE:-$HOME/.history}"
  if [[ ! -f "$histfile" ]]; then
    echo "hist-clean: HISTFILE not found: $histfile" >&2
    return 1
  fi

  # Extract commands, stripping zsh extended_history timestamps.
  local commands
  if [[ -n "$ZSH_VERSION" ]]; then
    # Strip ": epoch:elapsed;" prefix, skip continuation lines for display.
    commands=$(sed -n 's/^: [0-9]*:[0-9]*;//p' "$histfile")
  else
    commands=$(cat "$histfile")
  fi

  # Show unique commands sorted by most recent occurrence (last occurrence wins).
  # Use awk to deduplicate keeping the last occurrence, then reverse for most-recent-first.
  local selected
  selected=$(echo "$commands" | awk '{ lines[NR]=$0; last[$0]=NR } END { for(i=NR;i>=1;i--) if(last[lines[i]]==i) print lines[i] }' \
    | fzf --multi \
          --layout=reverse \
          --header='TAB to select, ENTER to confirm, ESC to cancel' \
          --prompt='hist-clean> ')

  if [[ -z "$selected" ]]; then
    echo "hist-clean: nothing selected."
    return 0
  fi

  # Build a set of commands to remove.
  local count=0
  local occurrences=0
  local tmpfile="${histfile}.tmp"

  # Write selected commands to a temp file for matching.
  local patternfile
  patternfile=$(mktemp)
  echo "$selected" > "$patternfile"

  local countfile
  countfile=$(mktemp)

  if [[ -n "$ZSH_VERSION" ]]; then
    # Process zsh extended_history: remove entries whose command matches.
    awk -v patternfile="$patternfile" -v countfile="$countfile" '
      BEGIN {
        while ((getline line < patternfile) > 0) {
          remove[line] = 1
        }
        close(patternfile)
        skip = 0
        removed = 0
      }
      /^: [0-9]+:[0-9]+;/ {
        cmd = $0
        sub(/^: [0-9]+:[0-9]+;/, "", cmd)
        if (cmd in remove) {
          skip = 1
          removed++
          next
        }
        skip = 0
        print
        next
      }
      {
        # Continuation line of a multi-line command.
        if (skip) next
        print
      }
      END {
        print removed > countfile
      }
    ' "$histfile" > "$tmpfile"
  else
    # Bash: one command per line.
    awk -v patternfile="$patternfile" -v countfile="$countfile" '
      BEGIN {
        while ((getline line < patternfile) > 0) {
          remove[line] = 1
        }
        close(patternfile)
        removed = 0
      }
      {
        if ($0 in remove) { removed++; next }
        print
      }
      END {
        print removed > countfile
      }
    ' "$histfile" > "$tmpfile"
  fi

  occurrences=$(cat "$countfile")
  rm -f "$patternfile" "$countfile"

  # Count unique entries selected.
  count=$(echo "$selected" | wc -l)

  mv "$tmpfile" "$histfile"
  fc -R

  echo "Removed $count $(if [[ $count -eq 1 ]]; then echo entry; else echo entries; fi) ($occurrences occurrences) from history:"
  echo "$selected" | while IFS= read -r cmd; do
    echo "  $cmd"
  done
}
