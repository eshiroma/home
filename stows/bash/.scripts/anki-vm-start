#!/bin/bash
# Start the auto-anki GCE VM and update ~/.ssh/config with its IP

INSTANCE=auto-anki-dev
ZONE=us-central1-a
PROJECT=firm-pentameter-309918
SSH_ALIAS=anki-vm

gcloud compute instances start "$INSTANCE" --zone="$ZONE" --project="$PROJECT" --quiet

IP=$(gcloud compute instances describe "$INSTANCE" \
  --zone="$ZONE" \
  --project="$PROJECT" \
  --format='get(networkInterfaces[0].accessConfigs[0].natIP)')

echo "VM IP: $IP"

# Update or insert Host block in ~/.ssh/config
if grep -q "^Host $SSH_ALIAS$" ~/.ssh/config 2>/dev/null; then
  # Update existing entry
  sed -i "/^Host $SSH_ALIAS$/,/^Host /{ s/HostName .*/HostName $IP/; }" ~/.ssh/config
else
  # Append new entry
  cat >> ~/.ssh/config << EOF

Host $SSH_ALIAS
  HostName $IP
  User $USER
  IdentityFile ~/.ssh/google_compute_engine
  StrictHostKeyChecking no
EOF
fi

echo "SSH config updated. Connect with: ssh $SSH_ALIAS"

# Wait for emulator to be ready
echo "Waiting for emulator..."
until gcloud compute ssh "$INSTANCE" --zone="$ZONE" --project="$PROJECT" --quiet \
  --command='export PATH=$PATH:/home/ubuntu/android-sdk/platform-tools && adb shell getprop sys.boot_completed 2>/dev/null' \
  2>/dev/null | grep -q "1"; do
  sleep 5
done
echo "Emulator ready. Dev loop is up."
