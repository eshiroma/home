#!/bin/bash
# Start the claude-worker GCE VM and update ~/.ssh/config with its IP

INSTANCE=claude-worker
ZONE=us-central1-a
PROJECT=firm-pentameter-309918
SSH_ALIAS=worker-vm

gcloud compute instances start "$INSTANCE" --zone="$ZONE" --project="$PROJECT" --quiet

IP=$(gcloud compute instances describe "$INSTANCE" \
  --zone="$ZONE" \
  --project="$PROJECT" \
  --format='get(networkInterfaces[0].accessConfigs[0].natIP)')

echo "VM IP: $IP"

# Update or insert Host block in ~/.ssh/config
if grep -q "^Host $SSH_ALIAS$" ~/.ssh/config 2>/dev/null; then
  sed -i "/^Host $SSH_ALIAS$/,/^Host /{ s/HostName .*/HostName $IP/; }" ~/.ssh/config
else
  cat >> ~/.ssh/config << EOF

Host $SSH_ALIAS
  HostName $IP
  User erika
  IdentityFile ~/.ssh/google_compute_engine
  StrictHostKeyChecking no
EOF
fi

echo "SSH config updated. Connect with: ssh $SSH_ALIAS"

# Wait for SSH to be ready (no emulator to wait for)
echo "Waiting for SSH..."
until ssh -o ConnectTimeout=5 -o StrictHostKeyChecking=no "$SSH_ALIAS" true 2>/dev/null; do
  sleep 3
done
echo "SSH ready. Connect with: ssh $SSH_ALIAS"
